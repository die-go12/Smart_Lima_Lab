# Copia este archivo como .env.local y rellena los valores (Supabase → Settings → API)
# Ambos son PÚBLICOS y seguros de exponer en el frontend (con RLS activado).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# NUNCA pongas aquí la Secret key (sb_secret_...). Esa es privada y solo va en
# variables de servidor o en el panel de Supabase, jamás en el frontend ni en git.
